{
  "name": "local-agents",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "serve": "bash scripts/serve.sh",
    "web": "bun run src/server/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test --path-ignore-patterns 'web/**'",
    "test:file": "bun test --path-ignore-patterns 'web/**'",
    "lint": "biome check .",
    "lint:file": "biome check",
    "lint:claude": "bun run lint",
    "docs:check": "bun run scripts/docs-check.ts",
    "check:web": "cd web && bun run typecheck && bun run test",
    "check": "bun run docs:check && bun run typecheck && bun run lint && bun run check:web && bun run test",
    "setup": "git config core.hooksPath .githooks && chmod +x .githooks/* && echo 'git hooks activated (.githooks)'",
    "setup:media": "bun run scripts/setup-media.ts",
    "setup:voice": "bun run scripts/setup-voice.ts",
    "discover": "bun run src/cli/discover.ts",
    "flow": "bun run src/cli/flow.ts",
    "crew": "bun run src/cli/crew.ts",
    "runs": "bun run src/cli/runs.ts",
    "memory": "bun run src/cli/memory.ts",
    "provision": "bun run src/cli/provision.ts",
    "mcp": "bun run src/cli/mcp.ts",
    "agent-builder": "bun run src/cli/agent-builder.ts",
    "crew-builder": "bun run src/cli/crew-builder.ts",
    "archive": "bun run src/cli/archive.ts",
    "config": "bun run src/cli/config.ts",
    "start": "bun run src/cli/start.ts",
    "status": "bun run src/cli/status.ts",
    "usage": "bun run src/cli/usage.ts"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^2.0.15",
    "@ai-sdk/openai-compatible": "^3.0.12",
    "@ai-sdk/otel": "^1.0.31",
    "@ai-sdk/provider-utils": "^5.0.11",
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "0.30.0",
    "@lmstudio/sdk": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "ai": "^7.0.31",
    "ollama-ai-provider-v2": "^4.0.1",
    "sherpa-onnx-node": "1.13.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@biomejs/biome": "2.5.1",
    "@types/bun": "^1.3.14"
  },
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs"
  ]
}
