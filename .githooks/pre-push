#!/bin/sh
# Documentation currency gate — slice-merge granularity.
# (1) Blocks a push whose commits change src/** but do NOT update docs/architecture.md.
# (2) On a push to main that changes docs/architecture.md (= a slice landed), also
#     requires README.md + docs/ROADMAP.md be updated in the same push, and reminds
#     to regenerate the interactive architecture Artifact (docs snapshot).
# Deliberate bypass (genuine no-doc-needed push): DOCS_OK=1 git push
# Activate once per clone with: bun run setup
[ "$DOCS_OK" = "1" ] && exit 0

ZERO="0000000000000000000000000000000000000000"
status=0

while read -r local_ref local_oid remote_ref remote_oid; do
  [ "$local_oid" = "$ZERO" ] && continue   # branch deletion
  if echo "$remote_oid" | grep -qE '^0+$'; then
    # new branch on the remote: diff against main, else the root commit
    base=$(git merge-base "$local_oid" origin/main 2>/dev/null \
      || git merge-base "$local_oid" main 2>/dev/null \
      || git rev-list --max-parents=0 "$local_oid" | head -1)
  else
    base="$remote_oid"
  fi
  # Fail closed: if we can't compute the diff, block (a gate must not pass on error).
  if ! changed=$(git diff --name-only "$base" "$local_oid" 2>/dev/null); then
    echo "✖ pre-push: could not diff $base..$local_oid — blocking as a safety measure."
    echo "  If this is a false alarm, bypass once with:  DOCS_OK=1 git push"
    status=1
    continue
  fi
  if echo "$changed" | grep -qE '^src/' && ! echo "$changed" | grep -qx 'docs/architecture.md'; then
    echo "✖ pre-push: src/ changed but docs/architecture.md was not updated in this push."
    echo "  The hard line: every shipped change keeps the architecture doc current."
    echo "  Update docs/architecture.md (+ the README map / docs/README.md), or, if a doc"
    echo "  change is genuinely not needed, bypass once with:  DOCS_OK=1 git push"
    status=1
  fi

  # Slice-landing gate (main only): a push to main that updates docs/architecture.md
  # means a slice shipped — the SAME push must also refresh the living status docs
  # (README status + slice table, ROADMAP status) and the interactive architecture
  # Artifact must be regenerated (not a repo file — reminded, not auto-checked).
  if [ "$remote_ref" = "refs/heads/main" ] && echo "$changed" | grep -qx 'docs/architecture.md'; then
    missing=""
    echo "$changed" | grep -qx 'README.md'       || missing="$missing README.md"
    echo "$changed" | grep -qx 'docs/ROADMAP.md'  || missing="$missing docs/ROADMAP.md"
    if [ -n "$missing" ]; then
      echo "✖ pre-push: docs/architecture.md changed on a push to main (a slice landed),"
      echo "  but these living status docs were not updated in the same push:$missing"
      echo "  The hard line: a slice updates architecture.md AND README (status + slice table)"
      echo "  AND docs/ROADMAP.md (status) — and you regenerate the interactive architecture"
      echo "  Artifact (docs snapshot) from architecture.md. Update them, or, if genuinely"
      echo "  not a slice (e.g. a typo fix), bypass once with:  DOCS_OK=1 git push"
      status=1
    else
      echo "ℹ pre-push: architecture.md + README + ROADMAP updated — also regenerate the"
      echo "  interactive architecture Artifact (docs snapshot) if the architecture changed."
    fi
  fi
done

exit $status
