      "x": 55, "y": 22, "width": 1200, "height": 38,
      "text": "Slice 32 — Self-Improvement Loop: continuous re-eval on model swap",
      "originalText": "Slice 32 — Self-Improvement Loop: continuous re-eval on model swap",
      "fontSize": 30, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0,
      "seed": 101001, "version": 1, "versionNonce": 1, "isDeleted": false, "groupIds": [],
      "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "subtitle",
      "x": 55, "y": 66, "width": 1400, "height": 44,
      "text": "The verified-build gate (Slice 20) checks an agent ONCE, at creation. Agents bind a requirement, not a model — so when the model underneath swaps, this loop\nreplays the frozen golden set against the NEW model and auto-demotes anything that silently regressed. Thick arrows = the primary re-eval flow.",
      "originalText": "The verified-build gate (Slice 20) checks an agent ONCE, at creation. Agents bind a requirement, not a model — so when the model underneath swaps, this loop\nreplays the frozen golden set against the NEW model and auto-demotes anything that silently regressed. Thick arrows = the primary re-eval flow.",
      "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0,
      "seed": 101002, "version": 1, "versionNonce": 1, "isDeleted": false, "groupIds": [],
