    { "type": "text", "id": "subtitle", "x": 60, "y": 74, "width": 1180, "height": 44, "text": "A web console that finally makes Slice 24's backend-only daemon + queue + remote-auth operable from the browser.\nThesis: most job endpoints already exist — this slice ADDS daemon/queue/device APIs, then a 4-tab Ops UI on top.", "originalText": "A web console that finally makes Slice 24's backend-only daemon + queue + remote-auth operable from the browser.\nThesis: most job endpoints already exist — this slice ADDS daemon/queue/device APIs, then a 4-tab Ops UI on top.", "fontSize": 16, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#475569", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 102, "version": 1, "versionNonce": 1, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

