    { "id": "ev_code", "type": "text", "x": 140, "y": 972, "width": 800, "height": 150, "angle": 0, "strokeColor": "#22c55e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 5003, "versionNonce": 5003, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "fontSize": 13, "fontFamily": 3, "text": "// Bun.serve idleTimeout:0 · req.signal → abortSignal\ncreateUIMessageStream({ execute: ({ writer }) => {\n  writer.write({ type:'data-delegation', transient:true,\n                 data:{ agent:'file_qa', depth:1 } })  // → live rail\n  writer.merge(orchestrator.toUIMessageStream())       // streamed answer\n}}) → createUIMessageStreamResponse()  // text/event-stream", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "// Bun.serve idleTimeout:0 · req.signal → abortSignal\ncreateUIMessageStream({ execute: ({ writer }) => {\n  writer.write({ type:'data-delegation', transient:true,\n                 data:{ agent:'file_qa', depth:1 } })  // → live rail\n  writer.merge(orchestrator.toUIMessageStream())       // streamed answer\n}}) → createUIMessageStreamResponse()  // text/event-stream", "lineHeight": 1.4 },

