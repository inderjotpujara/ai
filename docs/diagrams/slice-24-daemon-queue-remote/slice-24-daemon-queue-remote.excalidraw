    { "type": "text", "id": "lbl_client", "x": 28, "y": 138, "width": 165, "height": 25, "text": "① CLIENT", "originalText": "① CLIENT", "fontSize": 19, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100013, "version": 1, "versionNonce": 100014, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "cap_client", "x": 28, "y": 166, "width": 170, "height": 60, "text": "phone / laptop / CLI.\nSubmits jobs, polls or\nstreams status, holds a\nshort-lived session token.", "originalText": "phone / laptop / CLI.\nSubmits jobs, polls or\nstreams status, holds a\nshort-lived session token.", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100015, "version": 1, "versionNonce": 100016, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "lbl_daemon", "x": 28, "y": 306, "width": 175, "height": 25, "text": "② DAEMON + QUEUE", "originalText": "② DAEMON + QUEUE", "fontSize": 19, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#047857", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100017, "version": 1, "versionNonce": 100018, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "cap_daemon", "x": 28, "y": 334, "width": 175, "height": 90, "text": "the always-on core.\nPersistent SQLite job\nqueue + bounded worker\npool. Boot-recovery\nreconciles crashed jobs.", "originalText": "the always-on core.\nPersistent SQLite job\nqueue + bounded worker\npool. Boot-recovery\nreconciles crashed jobs.", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100019, "version": 1, "versionNonce": 100020, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "lbl_ai", "x": 28, "y": 521, "width": 170, "height": 25, "text": "③ AI · EXECUTION", "originalText": "③ AI · EXECUTION", "fontSize": 19, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#6d28d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100021, "version": 1, "versionNonce": 100022, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "cap_ai", "x": 28, "y": 549, "width": 170, "height": 75, "text": "runs each job.\nWorkflowAgent checkpoints\nper DAG node → resume\nfrom last completed node.", "originalText": "runs each job.\nWorkflowAgent checkpoints\nper DAG node → resume\nfrom last completed node.", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100023, "version": 1, "versionNonce": 100024, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "lbl_sec", "x": 28, "y": 691, "width": 175, "height": 25, "text": "④ SECURITY · TRANSPORT", "originalText": "④ SECURITY · TRANSPORT", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#c2410c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100025, "version": 1, "versionNonce": 100026, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "cap_sec", "x": 28, "y": 719, "width": 175, "height": 90, "text": "pluggable tunnel (we own\nbind + token, not the\ntunnel). Durable root token\nmints per-device session\ntokens. launchd keeps alive.", "originalText": "pluggable tunnel (we own\nbind + token, not the\ntunnel). Durable root token\nmints per-device session\ntokens. launchd keeps alive.", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100027, "version": 1, "versionNonce": 100028, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

