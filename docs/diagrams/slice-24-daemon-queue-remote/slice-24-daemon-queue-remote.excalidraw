    { "type": "text", "id": "title", "x": 210, "y": 22, "width": 1200, "height": 34, "text": "Slice 24 — Always-on Daemon + Task Queue + Resumable Jobs + Secure Remote Access", "originalText": "Slice 24 — Always-on Daemon + Task Queue + Resumable Jobs + Secure Remote Access", "fontSize": 28, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100001, "version": 1, "versionNonce": 100002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "subtitle", "x": 210, "y": 66, "width": 1250, "height": 40, "text": "Runs stop being request-scoped: a call ENQUEUES a job → returns a jobId → a worker pool runs it independently of any\nconnection → the job survives disconnect, restart, and crash. Reachable from anywhere via a pluggable tunnel.", "originalText": "Runs stop being request-scoped: a call ENQUEUES a job → returns a jobId → a worker pool runs it independently of any\nconnection → the job survives disconnect, restart, and crash. Reachable from anywhere via a pluggable tunnel.", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 100003, "version": 1, "versionNonce": 100004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

