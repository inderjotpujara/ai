    { "type": "rectangle", "id": "spine", "x": 40, "y": 766, "width": 1390, "height": 54, "strokeColor": "#1e40af", "backgroundColor": "#dbeafe", "fillStyle": "solid", "strokeWidth": 2.5, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 600001, "version": 1, "versionNonce": 600002, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "spine_t", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "spine_t", "x": 60, "y": 776, "width": 1350, "height": 36, "text": "The unifier: every flow ALSO writes spans → runs/<id>/spans.jsonl → appears in the Runs browser (kind facet: Build · Pull) — zero new stream code.\nInteractive flows (①) reuse Phase-2's data-confirm ↔ POST /api/runs/:id/respond. All routes are auto Host/Origin/token-gated under handleApi.", "originalText": "The unifier: every flow ALSO writes spans → runs/<id>/spans.jsonl → appears in the Runs browser (kind facet: Build · Pull) — zero new stream code.\nInteractive flows (①) reuse Phase-2's data-confirm ↔ POST /api/runs/:id/respond. All routes are auto Host/Origin/token-gated under handleApi.", "fontSize": 13, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#1e3a5f", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "seed": 600003, "version": 1, "versionNonce": 600004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "spine", "lineHeight": 1.25 },

