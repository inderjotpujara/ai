+        runsRoot: 'runs',
+        runId: `run-${process.pid}`,
+      });
+      console.log(result.kind === 'answer' ? result.text : result.message);
+    } finally {
+      await fetchServer.close();
+    }
+  } finally {
+    await fileServer.close();
+    await manager.unloadAll();
