+  expect(s).toContain('16384');
+  expect(s).toContain('installed');
+});
+
+test('not-installed notice announces a pull', () => {
+  const s = formatSelectionNotice({
+    decl,
+    numCtx: 16384,
+    budgetBytes: 12.3e9,
+    installed: false,
+  });
+  expect(s.toLowerCase()).toContain('pull');
+});
