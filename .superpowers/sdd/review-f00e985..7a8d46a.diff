+      members: [m('a'), m('b')],
+      tasks: [t('t1', 'a'), t('t2', 'b')],
+    });
+    expect(def.tasks).toHaveLength(2);
+  });
+
+  it('rejects a task assigned to an unknown member', () => {
+    expect(() =>
+      defineCrew({
+        id: 'c',
