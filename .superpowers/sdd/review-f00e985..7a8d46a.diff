+    {
+      name: 'researcher',
+      role: 'Analyst',
+      goal: 'gather',
+      backstory: 'b',
+      requires: [Capability.Tools],
+      prefer: PreferPolicy.LargestThatFits,
+    },
+    {
+      name: 'writer',
+      role: 'Writer',
+      goal: 'summarize',
