+      prefer: PreferPolicy.LargestThatFits,
+    },
+    {
+      name: 'writer',
+      role: 'Technical Writer',
+      goal: 'Turn research notes into a clear 3-bullet brief',
+      backstory: 'You write tight, plain summaries.',
+      requires: [Capability.Tools],
+      prefer: PreferPolicy.LargestThatFits,
+    },
+  ],
+  tasks: [
+    {
+      id: 'gather',
+      description:
