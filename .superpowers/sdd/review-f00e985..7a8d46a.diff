+    expect(s1.output).toBeDefined();
+  });
+
+  it('step input composes the task description + expected output', () => {
+    const wf = compileToWorkflow(crew);
+    const input = (
+      wf.steps[0] as { input: (c: Record<string, unknown>) => string }
