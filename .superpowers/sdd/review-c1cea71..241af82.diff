+        agent.name,
+        pre?.numCtx,
+        () => runDefinedAgent(agent, task, pre?.numCtx, pre?.model),
+      );
+      return { text: concise(text, callerNumCtx) };
+    } catch (cause) {
+      return {
+        error: `Agent ${agent.name} failed: ${(cause as Error).message}`,
+      };
+    }
+  });
+}
