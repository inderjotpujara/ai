+test('shutdown flushes in-flight writes before returning', async () => {
+  const file = join(dir, 'spans.jsonl');
+  const provider = new BasicTracerProvider({
+    spanProcessors: [new SimpleSpanProcessor(new JsonlFileExporter(file))],
