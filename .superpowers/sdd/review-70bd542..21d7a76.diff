+#!/bin/sh
+# Documentation currency gate — slice-merge granularity.
+# Blocks a push whose commits change src/** but do NOT update docs/architecture.md.
+# Deliberate bypass (genuine no-doc-needed push): DOCS_OK=1 git push
+# Activate once per clone with: bun run setup
+[ "$DOCS_OK" = "1" ] && exit 0
+
+ZERO="0000000000000000000000000000000000000000"
+status=0
+
+while read -r local_ref local_oid remote_ref remote_oid; do
+  [ "$local_oid" = "$ZERO" ] && continue   # branch deletion
+  if echo "$remote_oid" | grep -qE '^0+$'; then
+    # new branch on the remote: diff against main, else the root commit
+    base=$(git merge-base "$local_oid" origin/main 2>/dev/null \
+      || git merge-base "$local_oid" main 2>/dev/null \
+      || git rev-list --max-parents=0 "$local_oid" | tail -1)
+  else
+    base="$remote_oid"
+  fi
+  changed=$(git diff --name-only "$base" "$local_oid" 2>/dev/null)
+  if echo "$changed" | grep -qE '^src/' && ! echo "$changed" | grep -qx 'docs/architecture.md'; then
+    echo "✖ pre-push: src/ changed but docs/architecture.md was not updated in this push."
+    echo "  The hard line: every shipped change keeps the architecture doc current."
+    echo "  Update docs/architecture.md (+ the README map / docs/README.md), or, if a doc"
+    echo "  change is genuinely not needed, bypass once with:  DOCS_OK=1 git push"
+    status=1
+  fi
+done
+
+exit $status
