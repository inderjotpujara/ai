# Dependencies
node_modules/

# Run artifacts (per-run dirs + journals). Anchored to the repo root so
# src/features/runs/ (web UI feature area) stays tracked — see /memory/ below.
/runs/

# Memory datastore (LanceDB tables + bun:sqlite; local, never committed). See docs/architecture.md §11
# Anchored to the repo root so src/memory/ + tests/memory/ stay tracked.
/memory/

# Session/chat-history datastore (bun:sqlite; local, never committed). See docs/architecture.md
# Anchored to the repo root so src/session/ + tests/session/ stay tracked.
/sessions/

# Durable job-queue datastore (bun:sqlite; local, never committed) — the
# standalone web server self-hosts it at the default AGENT_QUEUE_PATH (Slice 24
# Incr 3). Anchored to the repo root so src/queue/ + tests/queue/ stay tracked.
/jobs/

# Local model image/blob files (large; never committed). See model-images/README.md
model-images/*
!model-images/.gitkeep
!model-images/README.md

# Session-continuity state is intentionally TRACKED (committed), not ignored, so it
# travels across machines: .superpowers/ (SDD ledger + task briefs/reports),
# .remember/ (session-memory .md buffers), .claude/settings.local.json, .githooks/.
# Only truly-transient junk stays ignored (below + .remember/{logs,tmp}).

# Vite build output (web/ workspace member); never committed
web/dist/

# Vitest browser-mode (voice e2e) run artifacts — failure screenshots +
# attachments; regenerated per run, never committed
web/.vitest-attachments/
web/src/**/__screenshots__/

# Misc
*.log
.DS_Store

# MCP mount trust store (machine-local approvals; never committed). See docs/architecture.md
.mcp-approvals.json
